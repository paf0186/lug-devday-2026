#!/bin/bash
# create-account — self-service workshop account creation.
#
# Run as `admin` on the workshop host after sshing in with the
# shared workshop passphrase.  Creates your personal account
# with a baseline gitconfig, passwordless sudo, and (optionally)
# your SSH public key.  Then log out and ssh back in as your
# new username.
#
# Usage:
#   create-account <username> "Full Name" <email>
#   create-account --force-password <username> "Full Name" <email>
#
# By default, refuses if the account already exists.  Re-run
# with --force-password to reset an existing account's password,
# pubkey, and gitconfig — the recovery path for a forgotten
# workshop passphrase.

set -euo pipefail

# Workshop passphrase, shared with everyone in the room.  Lives
# in a root-owned file written at host setup time; we read it
# via sudo because create-account itself runs as the unprivileged
# admin user.
LAB_PASSPHRASE_FILE="/etc/lab-passphrase"

usage() {
    cat >&2 <<'EOF'
Usage: create-account [--force-password] <username> "Full Name" <email>

  username    lowercase letters/digits/_-, max 31 chars, must start with a letter
  Full Name   shown in git commits to gerrit (quote it)
  email       shown in git commits to gerrit

  --force-password  reset password / pubkey / gitconfig if the account
                    already exists.  Use this if you forgot the workshop
                    passphrase or want to rotate your SSH key.

Example:
  create-account alice "Alice Example" alice@example.com

After creation, log out and ssh back in as yourself:
  ssh alice@devday1.mulberrytree.us
EOF
    exit 2
}

die() {
    echo "create-account: $*" >&2
    exit 1
}

# --- arg parsing ---------------------------------------------------------
FORCE_PASSWORD=0
while [[ $# -gt 0 && "$1" == --* ]]; do
    case "$1" in
        --force-password) FORCE_PASSWORD=1; shift ;;
        --help|-h) usage ;;
        --) shift; break ;;
        *) die "unknown flag: $1 (try --help)" ;;
    esac
done

[[ $# -eq 3 ]] || usage
USERNAME="$1"
FULLNAME="$2"
EMAIL="$3"

# Username sanity: must look like a real /etc/passwd entry, not
# a stray quote, '../', or shell metacharacter.
[[ "$USERNAME" =~ ^[a-z][a-z0-9_-]{0,30}$ ]] || die \
    "invalid username '$USERNAME': must match ^[a-z][a-z0-9_-]{0,30}\$"

# Email sanity: not bulletproof, just enough to catch obvious typos.
[[ "$EMAIL" =~ ^[^[:space:]@]+@[^[:space:]@]+\.[^[:space:]@]+$ ]] || die \
    "invalid email '$EMAIL'"

# Reserved names: never let an attendee hijack the shared login
# account that the lab depends on.
case "$USERNAME" in
    admin|root|nobody|sshd|systemd-*)
        die "'$USERNAME' is reserved -- pick a different username" ;;
esac

# --- read the workshop passphrase ----------------------------------------
sudo test -r "$LAB_PASSPHRASE_FILE" \
    || die "$LAB_PASSPHRASE_FILE missing -- ask the workshop organizer"
WORKSHOP_PASSWORD=$(sudo cat "$LAB_PASSPHRASE_FILE")
[[ -n "$WORKSHOP_PASSWORD" ]] || die "$LAB_PASSPHRASE_FILE is empty"

# --- existence check (refuse-by-default) ---------------------------------
if [[ $FORCE_PASSWORD -eq 0 ]] && id "$USERNAME" >/dev/null 2>&1; then
    die "account '$USERNAME' already exists.
       Pick a different username, OR re-run with --force-password to
       reset the existing account's password and SSH key (recovery
       path for a forgotten passphrase)."
fi

# --- pubkey paste --------------------------------------------------------
# Optional.  Blank line skips and falls back to password auth.
# We refuse loudly on anything that looks like a private key —
# pasting a private key into authorized_keys on a shared box
# where every other attendee has sudo would be a disaster.
echo
echo "Paste your SSH public key — the contents of ~/.ssh/id_ed25519.pub"
echo "from your laptop (the file ending in '.pub', not the private key)."
echo "Press Enter on a blank line to skip and use password auth instead."
read -r -p "key> " PUBKEY || PUBKEY=""

if [[ -n "$PUBKEY" ]]; then
    # Strip leading/trailing whitespace from the paste.
    PUBKEY="${PUBKEY#"${PUBKEY%%[![:space:]]*}"}"
    PUBKEY="${PUBKEY%"${PUBKEY##*[![:space:]]}"}"

    # Disaster check: did they paste their PRIVATE key?  PEM-encoded
    # private keys start with "-----BEGIN".  If we wrote that to
    # authorized_keys, every sudo-capable attendee on the host could
    # read it.  Refuse loudly with a recovery hint.
    if [[ "$PUBKEY" == "-----BEGIN"* ]]; then
        die "that looks like your *private* key.
       Paste the file ending in '.pub' instead — the contents of
       ~/.ssh/id_ed25519.pub, NOT ~/.ssh/id_ed25519.
       (Your private key should never leave your laptop.)"
    fi

    # Format check: openssh pubkey lines start with the algo name.
    # Allow ed25519, rsa, ecdsa, and security-key (sk-) variants.
    if [[ ! "$PUBKEY" =~ ^(ssh-(rsa|ed25519|dss)|ecdsa-sha2-|sk-) ]]; then
        die "that doesn't look like an SSH public key.
       Expected something starting with 'ssh-ed25519', 'ssh-rsa',
       or 'ecdsa-sha2-...'.  Re-run create-account and paste the
       contents of ~/.ssh/id_ed25519.pub from your laptop."
    fi

    # Multi-line paste means either a private key (caught above) or
    # a paste error — defensive check, since `read -r` shouldn't
    # consume newlines anyway.
    if [[ "$PUBKEY" == *$'\n'* ]]; then
        die "the key looks multi-line — paste only the single line from .pub"
    fi
fi

# --- provision the account -----------------------------------------------
# Single-host workshop: everything runs directly, no cross-host dispatch.

echo "==> Provisioning $USERNAME..."

sudo useradd -m -G wheel -s /bin/bash "$USERNAME" 2>/dev/null || true

# Set/reset the workshop passphrase.
echo "$USERNAME:$WORKSHOP_PASSWORD" | sudo chpasswd

# Passwordless sudo via per-user drop-in.  Mode 440 is what visudo
# writes; anything looser triggers a sudo parse-time warning.
echo "$USERNAME ALL=(ALL) NOPASSWD: ALL" \
    | sudo tee /etc/sudoers.d/"$USERNAME" >/dev/null
sudo chmod 440 /etc/sudoers.d/"$USERNAME"

# Baseline git identity for gerrit attribution.  -i runs as a login
# shell so HOME etc. are set; --global writes to ~/.gitconfig.
sudo -u "$USERNAME" -i git config --global user.name "$FULLNAME"
sudo -u "$USERNAME" -i git config --global user.email "$EMAIL"

# Resolve home dir from getent rather than tilde expansion: bash
# parses ~$USERNAME at the time the line is read, before useradd
# has a chance to land the user in /etc/passwd, so ~alice doesn't
# work the first time through.  getent passwd is the unambiguous
# source of truth.
user_home=$(getent passwd "$USERNAME" | cut -d: -f6)
[ -n "$user_home" ] || die "could not resolve home dir for $USERNAME"

sudo install -d -o "$USERNAME" -g "$USERNAME" -m 700 "$user_home/.ssh"

# Pubkey: REPLACE (not append).  This script is the user's only
# way to manage their authorized_keys, and "I rotated my key but
# the old one still works" would be a surprising default.  An
# empty PUBKEY skips this block entirely; the existing
# authorized_keys (if any) is left alone.
if [[ -n "$PUBKEY" ]]; then
    echo "$PUBKEY" | sudo tee "$user_home/.ssh/authorized_keys" >/dev/null
    sudo chown "$USERNAME":"$USERNAME" "$user_home/.ssh/authorized_keys"
    sudo chmod 600 "$user_home/.ssh/authorized_keys"
fi

# --- final instructions --------------------------------------------------
if [[ -n "$PUBKEY" ]]; then
    KEY_NOTE="(no password needed — your key is installed)"
else
    KEY_NOTE="(use the workshop passphrase from the slide)"
fi

cat <<EOF

==========================================
Account ready: $USERNAME
Identity:      $FULLNAME <$EMAIL>
==========================================

Log out (type 'exit' or hit Ctrl-D), then ssh back in as yourself:

  ssh $USERNAME@devday1.mulberrytree.us
  $KEY_NOTE

In VSCode, use Remote-SSH: Connect to Host with:

  $USERNAME@devday1.mulberrytree.us

EOF
