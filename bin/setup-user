#!/bin/bash
# setup-user — provision a workshop attendee account on hop + host1 + host2.
#
# Run as `admin` on the hop node:
#
#   setup-user <username> "Full Name" <email>
#
# Creates the user on all three boxes with a shared workshop password,
# passwordless sudo, and a baseline ~/.gitconfig.  Idempotent: safe to
# re-run if you tweak the name/email.
#
# Identity model: attendees never have an SSH key on the workshop boxes.
# They use SSH agent forwarding (`ssh -A`) so git on the host signs
# pushes with the key on their laptop.

set -euo pipefail

WORKSHOP_PASSWORD="welcome2026"

# Hosts to provision: localhost (the hop) plus any reachable workshop
# hosts.  We probe each candidate so the script works equally well
# during early lab buildout (host2 not yet provisioned) and on the day
# of (both hosts up).  Add new candidates to CANDIDATE_HOSTS as they
# come online -- the probe filters out the ones that don't resolve or
# don't accept ssh.
CANDIDATE_HOSTS=(host1 host2)
HOSTS=(localhost)
for h in "${CANDIDATE_HOSTS[@]}"; do
    if ssh -o BatchMode=yes -o ConnectTimeout=5 \
            -o StrictHostKeyChecking=no \
            "admin@$h" true 2>/dev/null; then
        HOSTS+=("$h")
    else
        echo "(skipping $h: not reachable)" >&2
    fi
done

usage() {
    cat >&2 <<EOF
Usage: setup-user <username> "Full Name" <email>

  username   lowercase letters/digits/_-, max 31 chars, must start with a letter
  Full Name  shown in git commits (quote it)
  email      shown in git commits

Example:
  setup-user alice "Alice Example" alice@example.com
EOF
    exit 2
}

die() {
    echo "setup-user: $*" >&2
    exit 1
}

# Refuse to run as root: this script invokes sudo on remote hosts via the
# admin user's passwordless sudo grant.  Running it as root locally would
# bypass that path and fall over on the remote ssh hop.
[[ $EUID -eq 0 ]] && die "do not run as root; run as 'admin' on the hop node"

[[ $# -eq 3 ]] || usage
USERNAME="$1"
FULLNAME="$2"
EMAIL="$3"

# Username sanity: a real /etc/passwd entry, not a stray quote or '../'.
[[ "$USERNAME" =~ ^[a-z][a-z0-9_-]{0,30}$ ]] || die \
    "invalid username '$USERNAME': must match ^[a-z][a-z0-9_-]{0,30}\$"

# Email sanity: not bulletproof, just enough to catch obvious typos.
[[ "$EMAIL" =~ ^[^[:space:]@]+@[^[:space:]@]+\.[^[:space:]@]+$ ]] || die \
    "invalid email '$EMAIL'"

# Workshop hosts (excludes localhost/hop).  Used both for round-robin
# assignment and for the closing instructions block.
WORKSHOP_HOSTS=()
for h in "${HOSTS[@]}"; do
    [[ "$h" != "localhost" ]] && WORKSHOP_HOSTS+=("$h")
done
[[ ${#WORKSHOP_HOSTS[@]} -gt 0 ]] || die \
    "no workshop hosts reachable -- nothing to assign $USERNAME to"

# Round-robin assignment: pick the workshop host with the fewest
# already-assigned attendees, ties broken by host order.  We persist
# each assignment as /var/lib/workshop-assignments/<user> on the hop
# (admin-writable, world-readable) so re-runs of setup-user are stable
# (an attendee keeps the same host across re-provisions) and so the
# count survives reboots.
ASSIGNMENT_DIR="/var/lib/workshop-assignments"
sudo install -d -m 755 "$ASSIGNMENT_DIR"

assignment_file="$ASSIGNMENT_DIR/$USERNAME"
if [[ -f "$assignment_file" ]]; then
    ASSIGNED_HOST=$(cat "$assignment_file")
    # Verify the previously assigned host is still in the reachable
    # set; if it dropped out (e.g. host2 retired), reassign.
    found=0
    for h in "${WORKSHOP_HOSTS[@]}"; do
        [[ "$h" == "$ASSIGNED_HOST" ]] && { found=1; break; }
    done
    if [[ $found -eq 0 ]]; then
        echo "(previous assignment $ASSIGNED_HOST no longer reachable, reassigning)" >&2
        ASSIGNED_HOST=""
    fi
fi

if [[ -z "${ASSIGNED_HOST:-}" ]]; then
    # Count current assignments per host, pick the lightest.
    least_count=999999
    least_host=""
    for h in "${WORKSHOP_HOSTS[@]}"; do
        count=$(grep -lFx "$h" "$ASSIGNMENT_DIR"/* 2>/dev/null | wc -l)
        if (( count < least_count )); then
            least_count=$count
            least_host=$h
        fi
    done
    ASSIGNED_HOST=$least_host
    echo "$ASSIGNED_HOST" | sudo tee "$assignment_file" >/dev/null
    sudo chmod 644 "$assignment_file"
fi

# Build the per-host provisioning script once and pipe it to bash on each
# target.  Heredoc-quoted so $USERNAME etc. are expanded HERE, not on the
# remote -- the remote shell sees concrete values, no interpolation games.
read -r -d '' REMOTE_SCRIPT <<EOF || true
set -e

# Create the user (idempotent: -m makes the home dir, || true so re-runs
# don't fail when it already exists).
if ! id "$USERNAME" >/dev/null 2>&1; then
    sudo useradd -m -G wheel -s /bin/bash "$USERNAME"
fi

# (Re)set the password every run so a forgotten password is one re-invoke
# away, and so the workshop password rotates cleanly when this script is
# updated.
echo "$USERNAME:$WORKSHOP_PASSWORD" | sudo chpasswd

# Passwordless sudo via a per-user drop-in so cleanup is just an unlink.
echo "$USERNAME ALL=(ALL) NOPASSWD: ALL" | \
    sudo tee /etc/sudoers.d/"$USERNAME" >/dev/null
sudo chmod 440 /etc/sudoers.d/"$USERNAME"

# Baseline git identity so commits attribute to the right human.
#
# Run from / so git doesn't pick up a containing repo from the cwd.
# When the script is invoked from a working dir with restrictive perms
# (e.g. ~admin/lug-devday-2026 with mode 700), git aborts with
# "fatal: failed to stat ..." before it gets a chance to look at
# --global at all.  --global writes to \$HOME/.gitconfig which is
# unaffected by cwd, but git still inspects cwd at startup.
sudo -u "$USERNAME" -i git config --global user.name "$FULLNAME"
sudo -u "$USERNAME" -i git config --global user.email "$EMAIL"

# Allow agent forwarding to land on the user's account: ssh-agent socket
# perms come from systemd, nothing to set up here -- but make sure the
# user's ~/.ssh exists with the right mode so an interactive ssh later
# doesn't trip on a missing dir.
#
# Resolve the home dir from getent rather than ~tilde expansion: bash
# evaluates ~user against the NSS user database in the *parent* shell
# at parse time, before useradd has a chance to land in passwd, and
# sudo -u doesn't re-run tilde expansion against the target user.
# getent passwd is the unambiguous source of truth.
user_home=\$(getent passwd "$USERNAME" | cut -d: -f6)
[ -n "\$user_home" ] || { echo "could not resolve home dir for $USERNAME" >&2; exit 1; }
sudo install -d -o "$USERNAME" -g "$USERNAME" -m 700 "\$user_home/.ssh"
EOF

provision_one() {
    local host="$1"
    if [[ "$host" == "localhost" ]]; then
        bash -c "$REMOTE_SCRIPT"
    else
        # ssh non-interactively; admin->{host1,host2} is keyed already.
        ssh -o BatchMode=yes -o StrictHostKeyChecking=no \
            "admin@$host" "$REMOTE_SCRIPT"
    fi
}

# Provision on the hop and on the user's assigned workshop host only.
# Skipping the unassigned host(s) is the simplest possible enforcement
# of the assignment: alice has no account on host2, so `ssh host2` from
# the hop fails with "Permission denied" -- no wrapper script, no shell
# magic, just /etc/passwd.
TARGETS=(localhost "$ASSIGNED_HOST")
for host in "${TARGETS[@]}"; do
    echo "==> Provisioning $USERNAME on $host..."
    if ! provision_one "$host"; then
        die "failed to provision $USERNAME on $host (see error above)"
    fi
done

# Generate a per-user SSH keypair on the hop and authorize it on the
# assigned workshop host so the attendee gets passwordless ssh to their
# host.  The private key lives in their hop home dir; the public key
# lands in their authorized_keys on the workshop host.  Both files are
# created idempotently -- re-running setup-user reuses the existing
# key (no churn) and re-authorizes it (recovers from a wiped
# authorized_keys).
echo "==> Setting up passwordless ssh: hop:$USERNAME -> $ASSIGNED_HOST:$USERNAME"
user_home_local=$(getent passwd "$USERNAME" | cut -d: -f6)
[[ -n "$user_home_local" ]] || die "could not resolve home dir for $USERNAME on hop"

if ! sudo test -f "$user_home_local/.ssh/id_ed25519"; then
    sudo -u "$USERNAME" ssh-keygen -t ed25519 -N "" \
        -f "$user_home_local/.ssh/id_ed25519" -C "$USERNAME@hop" \
        >/dev/null
fi
pubkey=$(sudo cat "$user_home_local/.ssh/id_ed25519.pub")

# Push the pubkey to authorized_keys on the assigned host.  Run via
# admin's ssh (passwordless), then sudo into root to write to the
# user's ~/.ssh.  Use install -m 600 so the file mode is correct
# whether or not it already exists.
ssh -o BatchMode=yes -o StrictHostKeyChecking=no \
    "admin@$ASSIGNED_HOST" "
        set -e
        user_home=\$(getent passwd '$USERNAME' | cut -d: -f6)
        sudo install -d -o '$USERNAME' -g '$USERNAME' -m 700 \"\$user_home/.ssh\"
        # Append-then-dedupe so re-runs don't grow the file unbounded
        # but a freshly-rotated key still lands.
        echo '$pubkey' | sudo tee -a \"\$user_home/.ssh/authorized_keys\" >/dev/null
        sudo chown '$USERNAME':'$USERNAME' \"\$user_home/.ssh/authorized_keys\"
        sudo chmod 600 \"\$user_home/.ssh/authorized_keys\"
        sudo -u '$USERNAME' awk '!seen[\$0]++' \"\$user_home/.ssh/authorized_keys\" \
            > /tmp/ak.\$\$ && sudo install -m 600 -o '$USERNAME' -g '$USERNAME' \
            /tmp/ak.\$\$ \"\$user_home/.ssh/authorized_keys\" && rm -f /tmp/ak.\$\$
    " || die "failed to install pubkey on $ASSIGNED_HOST"

cat <<EOF

Account ready: $USERNAME
Password:      $WORKSHOP_PASSWORD
Identity:      $FULLNAME <$EMAIL>
Assigned host: $ASSIGNED_HOST

Login from your laptop:
  ssh -A $USERNAME@devday.mulberrytree.us
  ssh $ASSIGNED_HOST            # passwordless from the hop

Or skip the hop with ProxyJump:
  ssh -A -J $USERNAME@devday.mulberrytree.us $USERNAME@$ASSIGNED_HOST

EOF
